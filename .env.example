# Airflow project directory (used for volume mounts)
AIRFLOW_PROJ_DIR=.

# Airflow UID — run `id -u` on Linux/Mac to get your user ID
AIRFLOW_UID=50000

# Postgres
POSTGRES_USER=airflow
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=airflow
POSTGRES_HOST=postgres

# Airflow admin user (created during init)
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=CHANGE_ME
_AIRFLOW_WWW_USER_EMAIL=admin@example.com
_AIRFLOW_WWW_USER_FIRSTNAME=Airflow
_AIRFLOW_WWW_USER_LASTNAME=Admin
_AIRFLOW_WWW_USER_ROLE=Admin

# Airflow secrets — regenerate for every environment
# Generate fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=CHANGE_ME
AIRFLOW__CORE__INTERNAL_API_SECRET_KEY=CHANGE_ME
AIRFLOW__API__SECRET_KEY=CHANGE_ME
AIRFLOW__API_AUTH__JWT_SECRET=CHANGE_ME

# Redis
REDIS_PASSWORD=CHANGE_ME

# Kafka Configuration
KAFKA_BROKER=kafka:9092
KAFKA_UI_PORT=8085

# Additional pip packages to install at container startup (space-separated)
_PIP_ADDITIONAL_REQUIREMENTS=

# Timezone
TZ=Asia/Kuala_Lumpur
